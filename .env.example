# ===== 大模型（LLM）配置 =====
# 用于"AI 生成解析规则"。本系统使用 Claude（Anthropic）。
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# 可选：覆盖默认模型
ANTHROPIC_MODEL=claude-opus-4-8

# ===== 数据库配置 =====
# 不设置 DATABASE_URL 时，本地自动使用 SQLite（./data/app.db）。
# 部署到 Vercel 时，通过 Neon Marketplace 集成自动注入 DATABASE_URL。
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
