# ===== 大模型（LLM）配置 =====
# 用于"AI 生成解析规则"。本系统使用 Claude（Anthropic）或其兼容中转。
#
# 方式一：官方 Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
#
# 方式二：兼容中转（如 vbcode.io）——用 AUTH_TOKEN + BASE_URL
# ANTHROPIC_AUTH_TOKEN=your-relay-token
# ANTHROPIC_BASE_URL=https://www.vbcode.io
#
# 可选：覆盖默认模型
ANTHROPIC_MODEL=claude-opus-4-8

# ===== 数据库配置 =====
# 不设置 DATABASE_URL 时，本地自动使用 SQLite（./data/app.db）。
# 部署到 Vercel 时，通过 Neon Marketplace 集成自动注入 DATABASE_URL。
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
